{
  "name": "openscad-web-generator",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/build.mjs",
    "build:wasm": "node scripts/download-wasm.mjs",
    "build:wasm:source": "node scripts/build-wasm.mjs",
    "build:bosl2": "node scripts/bundle-bosl2.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "apk": "cd android && gradle assembleDebug",
    "apk:install": "cd android && gradle assembleDebug && adb install -r app/build/outputs/apk/debug/app-debug.apk && adb shell am start -n io.github.mmmaxwwwell.openscadweb/.MainActivity",
    "apk:debug": "npm run build && npm run apk:install && adb logcat -c && adb logcat WebConsole:D OpenSCADWeb:D *:S"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@types/three": "^0.183.1",
    "earcut": "^3.0.2",
    "fflate": "^0.8.2",
    "idb": "^8.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.183.1"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  }
}
